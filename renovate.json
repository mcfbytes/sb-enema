{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "git-submodules": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Buildroot version in the Makefile",
      "managerFilePatterns": [
        "/(^|/)Makefile$/"
      ],
      "matchStrings": [
        "BUILDROOT_VERSION\\s*\\?=\\s*(?<currentValue>\\S+)"
      ],
      "depNameTemplate": "buildroot/buildroot",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "loose"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["custom.regex"],
      "matchDepNames": ["buildroot/buildroot"],
      "allowedVersions": "/^2026\\.02(\\.\\d+)?$/"
    },
    {
      "description": "Track the secureboot_objects submodule by plain vX.Y.Z tags only (not branch commits), ignoring the -signed variant",
      "matchManagers": ["git-submodules"],
      "matchDepNames": ["third_party/secureboot_objects"],
      "versioning": "semver-coerced",
      "allowedVersions": "/^v\\d+\\.\\d+\\.\\d+$/"
    }
  ]
}
