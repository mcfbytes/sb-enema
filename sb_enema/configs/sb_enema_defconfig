# Buildroot configuration for the SB-ENEMA secure boot reprovisioning environment.

# See also https://github.com/batocera-linux/batocera.linux/blob/master/configs/batocera-x86_64.board
# for an example configuration targeting x86_64 hardware.

# https://gitlab.com/buildroot.org/buildroot/-/blob/2025.11.2/Config.in?ref_type=tags

BR2_x86_64=y
BR2_TOOLCHAIN_BUILDROOT_GLIBC=y
BR2_GLOBAL_PATCH_DIR="../../sb_enema/patches"
BR2_ROOTFS_OVERLAY="../../sb_enema/board/sb-enema/rootfs-overlay"
BR2_TARGET_GENERIC_HOSTNAME="sb-enema"
BR2_TARGET_GENERIC_ISSUE="SB-ENEMA secure boot reprovisioning environment"
BR2_INIT_BUSYBOX=y
BR2_PACKAGE_BUSYBOX_CONFIG_FRAGMENT_FILES="../../sb_enema/board/sb-enema/busybox-fragment.config"

# /dev management — use devtmpfs + mdev for initramfs/CPIO boot
BR2_ROOTFS_DEVICE_CREATION_DYNAMIC_MDEV=y

# Networking and download tools
BR2_PACKAGE_LIBCURL_CURL=y

# Filesystem tooling
BR2_PACKAGE_EXFATPROGS=y

# Secure boot tooling
BR2_PACKAGE_OPENSSL=y
BR2_PACKAGE_LIBOPENSSL_BIN=y
BR2_PACKAGE_UTIL_LINUX=y
BR2_PACKAGE_UTIL_LINUX_LIBUUID=y
BR2_PACKAGE_GNU_EFI=y
BR2_PACKAGE_EFITOOLS=y
BR2_PACKAGE_SBSIGNTOOLS=y
BR2_PACKAGE_JQ=y

# System
BR2_PACKAGE_EFIBOOTMGR=y
BR2_TARGET_SYSLINUX=y
BR2_TARGET_SYSLINUX_MBR=y

# Kernel configuration
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_USE_DEFCONFIG=y
BR2_LINUX_KERNEL_DEFCONFIG="x86_64"
BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES="../../sb_enema/board/sb-enema/kernel-fragment.config"

# Bootloader
# BR2_TARGET_GRUB2=y
# BR2_TARGET_GRUB2_BUILTIN_CONFIG_EFI="../../sb_enema/board/sb-enema/grub.cfg"
# BR2_TARGET_GRUB2_X86_64_EFI=y
# BR2_TARGET_GRUB2_BUILTIN_MODULES_EFI="boot linux ext2 fat squash4 part_msdos part_gpt normal video video_fb gfxterm gfxmenu efi_gop gzio serial terminal terminfo search search_fs_file search_fs_uuid search_label echo"

# Host tooling required for image creation
BR2_PACKAGE_HOST_GENIMAGE=y
BR2_PACKAGE_HOST_DOSFSTOOLS=y
BR2_PACKAGE_HOST_MTOOLS=y

# Root filesystem
BR2_TARGET_ROOTFS_CPIO=y
BR2_TARGET_ROOTFS_CPIO_GZIP=y
BR2_ROOTFS_POST_BUILD_SCRIPT="../../sb_enema/board/sb-enema/post-build.sh"
BR2_ROOTFS_POST_IMAGE_SCRIPT="../../sb_enema/board/sb-enema/post-image.sh"

# Shell
BR2_PACKAGE_BUSYBOX_SHOW_OTHERS=y
BR2_PACKAGE_BASH=y