# Ensure blkid is available for device discovery
CONFIG_BLKID=y
CONFIG_FEATURE_BLKID_TYPE=y
CONFIG_MOUNTPOINT=y

# Enable fstab processing and UUID/label resolution in mount
CONFIG_FEATURE_MOUNT_FSTAB=y
CONFIG_FEATURE_MOUNT_LABEL=y

# Enable mdev rule file and script execution for automounting
CONFIG_FEATURE_MDEV_CONF=y
CONFIG_FEATURE_MDEV_EXEC=y
