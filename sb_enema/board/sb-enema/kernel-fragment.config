# EFI and secure boot helpers
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFIVAR_FS=y
CONFIG_EFI_PARTITION=y

# DMI/SMBIOS sysfs exposure
# CONFIG_DMIID populates /sys/class/dmi/id/ (bios_vendor, board_name, etc.)
# CONFIG_DMI_SYSFS exposes raw DMI tables under /sys/firmware/dmi/entries/ only.
CONFIG_DMIID=y
CONFIG_DMI_SYSFS=y

# Filesystem support
CONFIG_FAT_FS=y
CONFIG_VFAT_FS=y
CONFIG_EXFAT_FS=y
CONFIG_MSDOS_PARTITION=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y

# Loop devices for image staging
CONFIG_BLK_DEV_LOOP=y
CONFIG_BLK_DEV_RAM=y

# Overlay filesystem (read-only rootfs + mutable upper layer)
CONFIG_OVERLAY_FS=y

# Just run the kernel directly -- no GRUB
CONFIG_CMDLINE_BOOL=y
CONFIG_CMDLINE="rdinit=/init initrd=\\rootfs.cpio.gz console=tty0"
CONFIG_CMDLINE_OVERRIDE=y

# Framebuffer: EFI GOP only (VESA and simple-fb are legacy/ARM and can race
# with FB_EFI on UEFI-booted x86, producing a blank screen).
CONFIG_FB=y
CONFIG_FB_EFI=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE_DETECT_PRIMARY=y

# DRM simple framebuffer driver: preferred 6.x path for UEFI GOP handoff.
CONFIG_DRM=y
CONFIG_DRM_SIMPLEDRM=y
CONFIG_DRM_FBDEV_EMULATION=y

# USB support
CONFIG_USB=y
CONFIG_USB_SUPPORT=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_STORAGE=y

# Input for keyboard
CONFIG_HID=y
CONFIG_USB_HID=y
CONFIG_INPUT_KEYBOARD=y

# HW Random support
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_INTEL=y
CONFIG_HW_RANDOM_AMD=y
