# /etc/fstab — SB-ENEMA root filesystem mount table
#
# The data partition is listed here for reference only.  BusyBox mount does
# not support UUID= lookups (no libblkid linkage), so the entry is marked
# noauto.  The actual mount is performed by mdev via /lib/mdev/mount-data.sh
# which parses `blkid <dev>` output directly.
#
# <file system>     <mount pt>  <type>  <options>                   <dump>  <pass>
sysfs               /sys        sysfs   defaults                   0       0
UUID=BEEF-CAFE      /mnt/data   vfat    noauto,nofail              0       0
