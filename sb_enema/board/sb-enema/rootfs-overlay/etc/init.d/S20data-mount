#!/bin/sh
# S20data-mount — Mount the SB-ENEMA FAT32 data partition early in boot.

case "$1" in
    start)
        echo "Mounting SB-ENEMA data partition"
        if mountpoint -q /mnt/data 2>/dev/null; then
            echo "/mnt/data already mounted"
        else
            timeout="${MOUNT_WAIT_TIMEOUT:-15}"

            # Replay cold-plug events so mdev.conf rules fire for any block
            # devices that appeared before the mdev daemon started.  The actual
            # mount is handled by /lib/mdev/mount-data.sh via the mdev.conf
            # rules — we just need to trigger it and then wait for it to finish.
            mdev -s 2>/dev/null || true

            # mdev event processing is asynchronous; block here until
            # /mnt/data is mounted or the timeout expires so that later init
            # scripts (S40sb-enema, etc.) always see the partition ready.
            waited=0
            while [ "${waited}" -lt "${timeout}" ]; do
                mountpoint -q /mnt/data 2>/dev/null && break
                sleep 1
                waited=$((waited + 1))
            done

            if mountpoint -q /mnt/data 2>/dev/null; then
                echo "/mnt/data mounted"
            else
                echo "Warning: /mnt/data not mounted after ${timeout}s (check dmesg)"
            fi
        fi
        ;;
    stop)
        if umount /mnt/data 2>/dev/null; then
            echo "Unmounted /mnt/data"
        else
            echo "Warning: Could not unmount /mnt/data (busy or not mounted)"
        fi
        ;;
    *)
        echo "Usage: $0 {start|stop}" >&2
        exit 1
        ;;
esac
