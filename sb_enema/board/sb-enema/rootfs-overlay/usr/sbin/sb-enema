#!/usr/bin/env bash
# sb-enema — Main entry point for the SB-ENEMA Secure Boot provisioning tool.
set -euo pipefail

# ---------------------------------------------------------------------------
# Locate the library directory relative to this script so that the overlay
# layout is self-contained regardless of where it is installed.
# ---------------------------------------------------------------------------
LIB_DIR="/usr/lib/sb-enema"

source "${LIB_DIR}/common.sh"
source "${LIB_DIR}/log.sh"
source "${LIB_DIR}/mount.sh"
source "${LIB_DIR}/efivar.sh"
source "${LIB_DIR}/certdb.sh"
source "${LIB_DIR}/safety.sh"
source "${LIB_DIR}/audit.sh"
source "${LIB_DIR}/report.sh"
source "${LIB_DIR}/update.sh"
source "${LIB_DIR}/preview.sh"
source "${LIB_DIR}/keygen.sh"
source "${LIB_DIR}/stage.sh"
source "${LIB_DIR}/bootloader-scan.sh"
source "${LIB_DIR}/enroll.sh"

# ---------------------------------------------------------------------------
# Version string — updated at release time.
# ---------------------------------------------------------------------------
VERSION="@@VERSION@@"
[[ "${VERSION}" == "@@VERSION@@" ]] && VERSION="manual-build"

# ---------------------------------------------------------------------------
# print_banner() — display the project name and version.
# ---------------------------------------------------------------------------
print_banner() {
    echo -e "${BOLD}"
    echo "  ███████╗██████╗       ███████╗███╗   ██╗███████╗███╗   ███╗ █████╗ "
    echo "  ██╔════╝██╔══██╗      ██╔════╝████╗  ██║██╔════╝████╗ ████║██╔══██╗"
    echo "  ███████╗██████╔╝█████╗█████╗  ██╔██╗ ██║█████╗  ██╔████╔██║███████║"
    echo "  ╚════██║██╔══██╗╚════╝██╔══╝  ██║╚██╗██║██╔══╝  ██║╚██╔╝██║██╔══██║"
    echo "  ███████║██████╔╝      ███████╗██║ ╚████║███████╗██║ ╚═╝ ██║██║  ██║"
    echo "  ╚══════╝╚═════╝       ╚══════╝╚═╝  ╚═══╝╚══════╝╚═╝     ╚═╝╚═╝  ╚═╝"
    echo -e "${RESET}"
    echo -e "  ${BOLD}SB-ENEMA${RESET} — Secure Boot Enrollment & Management Assistant  v${VERSION}"
    echo    "  Because sometimes your UEFI needs a deep cleaning."
    echo
}

# ---------------------------------------------------------------------------
# cleanup() — trap handler for EXIT, INT, TERM
# ---------------------------------------------------------------------------
cleanup() {
    local exit_code=$?
    log_info "Cleaning up and saving session logs..."

    # Write data to disk before exiting to ensure logs are saved
    sync

    # Display log location if log file was initialized
    if [[ -n "${LOG_FILE:-}" ]] && [[ -f "${LOG_FILE}" ]]; then
        echo -e "${DIM}Logs saved to ${LOG_FILE}${RESET}"
    fi

    exit "${exit_code}"
}

# ---------------------------------------------------------------------------
# show_menu() — display the main menu options
# ---------------------------------------------------------------------------
show_menu() {
    echo
    echo -e "${BOLD}  ═══════════════════════════════════════════════${RESET}"
    echo -e "${BOLD}   Quick Actions${RESET}"
    echo -e "${BOLD}  ═══════════════════════════════════════════════${RESET}"
    echo "  [1]  View Secure Boot report"
    echo "  [2]  Full Colonic — User PK/KEK + Microsoft db/dbx → enroll"
    echo "  [3]  Microsoft Colonic — Microsoft PK/KEK/db/dbx → enroll"
    echo "  [4]  Microsoft Suppository — Add missing Microsoft KEK/db/dbx (keep PK) → enroll"
    echo
    echo -e "${BOLD}  ═══════════════════════════════════════════════${RESET}"
    echo -e "${BOLD}   Staging (advanced)${RESET}"
    echo -e "${BOLD}  ═══════════════════════════════════════════════${RESET}"
    echo "  [5]  Stage Microsoft PK"
    echo "  [6]  Stage Microsoft KEK, DB, DBX"
    echo "  [7]  Stage User-generated PK & KEK"
    echo "  [8]  Stage User-generated KEK, DB"
    echo "  [9]  Stage vendor default entries (KEKDefault/dbDefault certs, vendor filter applied)"
    echo "  [10] Show staged delta (what will change)"
    echo "  [11] Clear staging area"
    echo "  [12] Apply staged changes (enroll)"
    echo
    echo -e "${BOLD}  ═══════════════════════════════════════════════${RESET}"
    echo "  [13] Set certificate CN (name prefix)"
    echo "  [14] Restore OEM Defaults — BIOS instructions"
    echo "  [15] Exit"
    echo
    echo -e "${BOLD}  ═══════════════════════════════════════════════${RESET}"
    echo "  [B]  Scan bootloader CA certificates"
    echo
}

# ---------------------------------------------------------------------------
# handle_option_1() — View Secure Boot report
# ---------------------------------------------------------------------------
handle_option_1() {
    log_info "Menu selection: View Secure Boot report"
    echo
    report_full
}

# ---------------------------------------------------------------------------
# handle_full_colonic() — User PK/KEK + Microsoft db/dbx
# [2] Full Colonic
# ---------------------------------------------------------------------------
handle_full_colonic() {
    log_info "Menu selection: Full Colonic"
    echo
    echo -e "${BOLD}Full Colonic — User PK/KEK + Microsoft db/dbx${RESET}"
    echo

    stage_clear || { log_error "Failed to clear staging area"; return 1; }

    keygen_generate_keys || { log_error "Failed to generate keys"; return 1; }

    stage_user_pk_kek || { log_error "Failed to stage user PK/KEK"; return 1; }

    stage_microsoft_kek_db_dbx || { log_error "Failed to stage Microsoft KEK/DB/DBX"; return 1; }

    # Rebuild db.auth fresh from all staged db certs, signed by user KEK.
    # stage_microsoft_kek_db_dbx copies the pre-signed MS db.auth which has a
    # stale timestamp; firmware monotonic counters reject it even in Setup Mode.
    stage_sign_db || { log_error "Failed to sign db.auth"; return 1; }

    enroll || { log_error "Enrollment failed"; return 1; }

    log_success "Full Colonic completed successfully"
}

# ---------------------------------------------------------------------------
# handle_microsoft_colonic() — Microsoft PK/KEK/db/dbx
# [3] Microsoft Colonic
# ---------------------------------------------------------------------------
handle_microsoft_colonic() {
    log_info "Menu selection: Microsoft Colonic"
    echo
    echo -e "${BOLD}Microsoft Colonic — Microsoft PK/KEK/db/dbx${RESET}"
    echo

    echo -e "${YELLOW}  ⚠  This will replace your vendor's Platform Key with Microsoft's.${RESET}"
    echo -e "${YELLOW}  ⚠  OEM-specific Secure Boot features may stop working.${RESET}"
    echo -e "${YELLOW}  ⚠  Microsoft PK enrollment is untested; some firmware (e.g. QEMU/OVMF)${RESET}"
    echo -e "${YELLOW}     may reject unsigned PK payloads even in Setup Mode.${RESET}"
    echo -e "${GREEN}  ✓  This is reversible: use your BIOS 'Restore Factory Keys' option.${RESET}"
    echo -e "${DIM}  ℹ  Trusting Redmond over your OEM — in Microsoft we trust.${RESET}"
    echo

    stage_clear || { log_error "Failed to clear staging area"; return 1; }

    stage_microsoft_pk || { log_error "Failed to stage Microsoft PK"; return 1; }

    stage_microsoft_kek_db_dbx || { log_error "Failed to stage Microsoft KEK/DB/DBX"; return 1; }

    enroll || { log_error "Microsoft Colonic enrollment failed"; return 1; }

    log_success "Microsoft Colonic completed successfully"
}

# ---------------------------------------------------------------------------
# handle_microsoft_suppository() — Add missing Microsoft KEK/db/dbx (keep PK)
# [4] Microsoft Suppository
# ---------------------------------------------------------------------------
handle_microsoft_suppository() {
    log_info "Menu selection: Microsoft Suppository"
    echo
    echo -e "${BOLD}Microsoft Suppository — Add missing Microsoft KEK/db/dbx${RESET}"
    echo
    echo -e "${DIM}  This keeps your current PK and only updates KEK/db/dbx${RESET}"
    echo -e "${DIM}  with Microsoft's pre-signed payloads.${RESET}"
    echo

    stage_clear || { log_error "Failed to clear staging area"; return 1; }

    stage_microsoft_kek_db_dbx || { log_error "Failed to stage Microsoft KEK/DB/DBX"; return 1; }
    stage_dbx_with_pca2011_check || log_warn "DBX staging with PCA 2011 check encountered issues"

    enroll || { log_error "Microsoft Suppository enrollment failed"; return 1; }

    log_success "Microsoft Suppository completed successfully"
}

# ---------------------------------------------------------------------------
# handle_stage_microsoft_pk() — Stage Microsoft PK
# [5]
# ---------------------------------------------------------------------------
handle_stage_microsoft_pk() {
    log_info "Menu selection: Stage Microsoft PK"
    echo
    echo -e "${YELLOW}  ⚠  Microsoft PK enrollment is untested; some firmware (e.g. QEMU/OVMF)${RESET}"
    echo -e "${YELLOW}     may reject unsigned PK payloads even in Setup Mode.${RESET}"
    echo
    stage_microsoft_pk || { log_error "Failed to stage Microsoft PK"; return 1; }
    stage_show
}

# ---------------------------------------------------------------------------
# handle_stage_microsoft_kek_db_dbx() — Stage Microsoft KEK, DB, DBX
# [6]
# ---------------------------------------------------------------------------
handle_stage_microsoft_kek_db_dbx() {
    log_info "Menu selection: Stage Microsoft KEK, DB, DBX"
    echo
    stage_microsoft_kek_db_dbx || { log_error "Failed to stage Microsoft KEK/DB/DBX"; return 1; }
    stage_show
}

# ---------------------------------------------------------------------------
# handle_stage_user_pk_kek() — Stage User-generated PK & KEK
# [7]
# ---------------------------------------------------------------------------
handle_stage_user_pk_kek() {
    log_info "Menu selection: Stage User-generated PK & KEK"
    echo
    keygen_generate_keys || { log_error "Failed to generate keys"; return 1; }
    stage_user_pk_kek || { log_error "Failed to stage user PK/KEK"; return 1; }
    stage_show
}

# ---------------------------------------------------------------------------
# handle_stage_user_kek_db() — Stage User-generated KEK, DB
# [8]
# ---------------------------------------------------------------------------
handle_stage_user_kek_db() {
    log_info "Menu selection: Stage User-generated KEK, DB"
    echo
    keygen_generate_keys || { log_error "Failed to generate keys"; return 1; }
    stage_user_kek_db || { log_error "Failed to stage user KEK/DB"; return 1; }
    stage_show
}

# ---------------------------------------------------------------------------
# handle_stage_bios_entries() — Stage vendor default entries
# [9]
# ---------------------------------------------------------------------------
handle_stage_bios_entries() {
    log_info "Menu selection: Stage vendor default entries"
    echo
    stage_bios_entries || { log_error "Failed to stage vendor default entries"; return 1; }
    stage_show
}

# ---------------------------------------------------------------------------
# handle_show_delta() — Show staged delta
# [10]
# ---------------------------------------------------------------------------
handle_show_delta() {
    log_info "Menu selection: Show staged delta"
    echo
    stage_show_delta
}

# ---------------------------------------------------------------------------
# handle_clear_staging() — Clear staging area
# [11]
# ---------------------------------------------------------------------------
handle_clear_staging() {
    log_info "Menu selection: Clear staging area"
    echo
    stage_clear || { log_error "Failed to clear staging area"; return 1; }
    echo -e "${GREEN}  Staging area cleared.${RESET}"
    echo
}

# ---------------------------------------------------------------------------
# handle_apply() — Apply staged changes
# [12]
# ---------------------------------------------------------------------------
handle_apply() {
    log_info "Menu selection: Apply staged changes"
    echo
    enroll || { log_error "Enrollment failed"; return 1; }
}

# ---------------------------------------------------------------------------
# handle_set_cert_cn() — Set certificate CN (name prefix)
# [13]
# ---------------------------------------------------------------------------
handle_set_cert_cn() {
    log_info "Menu selection: Set certificate CN prefix"
    echo
    echo -e "${BOLD}Set Certificate CN (Name Prefix)${RESET}"
    echo
    echo "Enter the name prefix for the Common Name (CN) of user-generated"
    echo "certificates (PK, KEK, and DB). Press Enter to keep the current value."
    echo
    local cn_input
    read -rp "  Certificate name prefix [${CERT_CN_PREFIX}]: " cn_input
    if [[ -n "${cn_input}" ]]; then
        local sanitized
        sanitized=$(_keygen_sanitize_dn_field "${cn_input}")
        if [[ "${sanitized}" == "Unknown" ]]; then
            echo -e "${YELLOW}  Input was empty or invalid after sanitization; keeping current prefix: ${CERT_CN_PREFIX}${RESET}"
            log_info "Certificate CN prefix input sanitized to sentinel 'Unknown'; keeping existing prefix: ${CERT_CN_PREFIX}"
        else
            CERT_CN_PREFIX="${sanitized}"
            echo -e "${GREEN}  Certificate CN prefix set to: ${CERT_CN_PREFIX}${RESET}"
            log_info "Certificate CN prefix set to: ${CERT_CN_PREFIX}"
        fi
    else
        echo -e "${DIM}  Keeping current prefix: ${CERT_CN_PREFIX}${RESET}"
    fi
    echo
    echo -e "${DIM}  Note: This prefix is applied when keys and certificates are next generated.${RESET}"
    echo -e "${DIM}        Existing valid certificates may keep their current Common Name until${RESET}"
    echo -e "${DIM}        they expire or are explicitly regenerated.${RESET}"
    echo
}

# ---------------------------------------------------------------------------
# handle_option_14() — Restore OEM Defaults instructions
# [14]
# ---------------------------------------------------------------------------
handle_option_14() {
    log_info "Menu selection: Restore OEM Defaults instructions"
    echo
    echo -e "${BOLD}Restore OEM Defaults — BIOS Instructions${RESET}"
    echo
    echo "To restore your motherboard's factory Secure Boot keys, use your"
    echo "BIOS/UEFI firmware setup utility. This is the safest way to return"
    echo "to the vendor's original configuration."
    echo
    echo -e "${BOLD}Common Access Methods:${RESET}"
    echo
    echo "  • During POST (power-on), press DEL, F2, F10, or F12"
    echo "  • Look for 'Press [KEY] to enter Setup' message"
    echo
    echo -e "${BOLD}Navigation (varies by vendor):${RESET}"
    echo
    echo "  ASUS:      Advanced → Secure Boot → Key Management"
    echo "             Look for 'Restore Factory Keys' or 'Install Default Secure Boot keys'"
    echo
    echo "  MSI:       Settings → Security → Secure Boot"
    echo "             Select 'Restore Factory Defaults' or 'Restore Factory Keys'"
    echo
    echo "  Gigabyte:  BIOS Features → Secure Boot Configuration"
    echo "             Choose 'Restore Factory Keys' or similar option"
    echo
    echo "  ASRock:    Security → Secure Boot"
    echo "             Find 'Restore Factory Default Keys' option"
    echo
    echo "  Dell:      Boot Configuration → Secure Boot"
    echo "             Select 'Restore Factory Settings' or 'Reset to Setup Mode'"
    echo
    echo "  Lenovo:    Security → Secure Boot → Key Management"
    echo "             Choose 'Restore Factory Keys'"
    echo
    echo -e "${YELLOW}Important:${RESET}"
    echo "  • This operation typically requires Setup Mode to be enabled first"
    echo "  • Some vendors call this 'Clear Secure Boot Keys' + 'Install Default Keys'"
    echo "  • After restoring, you may need to re-enable Secure Boot"
    echo "  • This will NOT affect your OS or data, only firmware variables"
    echo
    echo -e "${DIM}Note: Exact menu paths vary by motherboard model and BIOS version.${RESET}"
    echo -e "${DIM}Consult your motherboard manual for specific instructions.${RESET}"
    echo
}

# ---------------------------------------------------------------------------
# handle_option_15() — Exit
# [15]
# ---------------------------------------------------------------------------
handle_option_15() {
    log_info "Menu selection: Exit"
    echo
    echo "Exiting SB-ENEMA. Thank you for using this tool."
    exit 0
}

# ---------------------------------------------------------------------------
# handle_scan_bootloaders() — Scan bootloader CA certificates
# [B]
# ---------------------------------------------------------------------------
handle_scan_bootloaders() {
    log_info "Menu selection: Scan bootloader CA certificates"
    echo
    echo -e "${BOLD}Scanning EFI bootloader CA certificates…${RESET}"
    echo
    bootloader_scan_pca2011_in_use || true
    bootloader_scan_log_summary
}

# ---------------------------------------------------------------------------
# run_menu_loop() — Main interactive menu loop
# ---------------------------------------------------------------------------
run_menu_loop() {
    while true; do
        show_menu

        local choice
        read -rp "Enter your choice [1-15 or B]: " choice

        case "${choice}" in
            1)  handle_option_1 ;;
            2)  handle_full_colonic ;;
            3)  handle_microsoft_colonic ;;
            4)  handle_microsoft_suppository ;;
            5)  handle_stage_microsoft_pk ;;
            6)  handle_stage_microsoft_kek_db_dbx ;;
            7)  handle_stage_user_pk_kek ;;
            8)  handle_stage_user_kek_db ;;
            9)  handle_stage_bios_entries ;;
            10) handle_show_delta ;;
            11) handle_clear_staging ;;
            12) handle_apply ;;
            13) handle_set_cert_cn ;;
            14) handle_option_14 ;;
            15) handle_option_15 ;;
            [Bb]) handle_scan_bootloaders ;;
            *)
                echo -e "${RED}Invalid choice. Please enter a number between 1 and 15 or B.${RESET}"
                log_warn "Invalid menu selection: ${choice}"
                ;;
        esac
    done
}

# ---------------------------------------------------------------------------
# run_cli_mode() — Execute CLI operations non-interactively
# ---------------------------------------------------------------------------
run_cli_mode() {
    local operation="${1:-}"

    case "${operation}" in
        report|view-report)
            handle_option_1
            ;;
        full-colonic)
            handle_full_colonic
            ;;
        microsoft-colonic)
            handle_microsoft_colonic
            ;;
        microsoft-suppository)
            handle_microsoft_suppository
            ;;
        stage-microsoft-pk)
            handle_stage_microsoft_pk
            ;;
        stage-microsoft-kek-db-dbx)
            handle_stage_microsoft_kek_db_dbx
            ;;
        stage-user-pk-kek)
            handle_stage_user_pk_kek
            ;;
        stage-user-kek-db)
            handle_stage_user_kek_db
            ;;
        stage-bios-entries)
            handle_stage_bios_entries
            ;;
        show-delta)
            handle_show_delta
            ;;
        clear-staging)
            handle_clear_staging
            ;;
        apply)
            handle_apply
            ;;
        restore-instructions)
            handle_option_14
            ;;
        scan-bootloaders)
            handle_scan_bootloaders
            ;;
        *)
            echo -e "${RED}Error: Unknown CLI operation '${operation}'${RESET}" >&2
            echo >&2
            echo "Usage: sb-enema [OPERATION]" >&2
            echo >&2
            echo "Operations:" >&2
            echo "  report                  View Secure Boot report" >&2
            echo "  full-colonic            User PK/KEK + Microsoft db/dbx" >&2
            echo "  microsoft-colonic       Microsoft PK/KEK/db/dbx enrollment" >&2
            echo "  microsoft-suppository   Add missing Microsoft KEK/db/dbx (keep PK)" >&2
            echo "  stage-microsoft-pk      Stage Microsoft PK" >&2
            echo "  stage-microsoft-kek-db-dbx  Stage Microsoft KEK, DB, DBX" >&2
            echo "  stage-user-pk-kek       Stage user-generated PK & KEK" >&2
            echo "  stage-user-kek-db       Stage user-generated KEK, DB" >&2
            echo "  stage-bios-entries      Stage recognized vendor KEKDefault/dbDefault entries" >&2
            echo "  show-delta              Show staged delta" >&2
            echo "  clear-staging           Clear staging area" >&2
            echo "  apply                   Apply staged changes" >&2
            echo "  restore-instructions    Show BIOS factory reset instructions" >&2
            echo "  scan-bootloaders        Scan EFI bootloader CA certificates" >&2
            echo >&2
            echo "If no operation is specified, the interactive menu is shown." >&2
            exit 1
            ;;
    esac
}

# ---------------------------------------------------------------------------
# main() — bootstrap environment and hand off to menu or CLI mode
# ---------------------------------------------------------------------------
main() {
    # Set up trap handler for cleanup
    trap cleanup EXIT INT TERM

    require_root

    # Mount efivarfs and the data partition first
    mount_efivars
    mount_data_partition

    # Initialize the log file on the data partition after it is mounted
    log_init

    print_banner

    # Run audit automatically on startup
    log_info "Running Secure Boot audit..."


    # Display full report automatically
    report_full

    # Check if CLI mode was requested
    if [[ $# -gt 0 ]]; then
        log_info "Operating in CLI mode"
        run_cli_mode "$1"
    else
        # Interactive menu mode
        log_info "Starting interactive menu"
        run_menu_loop
    fi
}

main "$@"
